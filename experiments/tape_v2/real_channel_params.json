  "spectral_contamination": {
    "_about": "THE KEY TERM the sim lacks. On known-lit-tone symbols, fraction of per-tone energy landing OUTSIDE the K lit tones (after sounder-H(f) EQ). Genie-aligned per symbol so this is NOT a timing artifact.",
    "offtone_leakage_frac_aligned_M16_N77": 0.3736253208231105,
    "offtone_leakage_frac_aligned_M32_N159": 0.30675997266139243,
    "offtone_leakage_frac_all_M16_N77_median": 0.42038990699001777,
    "offtone_leakage_frac_all_M32_N159_median": 0.3383044484857136,
    "adjacent_bin_leakage_M16": 0.1118268823487739,
    "adjacent_bin_leakage_M32": 0.047205620941365496,
    "distant_bin_leakage_M16": 0.24032119008367533,
    "distant_bin_leakage_M32": 0.251462001765902,
    "spurious_third_over_litmin_M16": 0.8985899999869853,
    "spurious_third_over_litmin_M32": 0.7457559095182196,
    "scaling": {
      "symbol_len_samples_M16": 77,
      "symbol_len_samples_M32": 159,
      "bin_width_hz_M16": 623.4,
      "bin_width_hz_M32": 301.9,
      "leakage_drop_db_per_2x_symbol_len": 0.9434457212240508,
      "reverb_tail_tau_ms": 7.8639366656459,
      "leak_model_A": 0.5155183574062718,
      "leak_model": "leak(N) ~= A*exp(-N/tau_samples); tau~7.9ms. NOTE: this single-exponential lumps two mechanisms (see two_mechanisms)."
    },
    "two_mechanisms": {
      "adjacent_bin": "FFT-skirt + adjacent-symbol smear into +/-1 bins. SHRINKS with longer symbols: 0.112 (M16) -> 0.047 (M32), ~halves per 2x symbol length / halved bin width.",
      "distant_diffuse": "A flat ~0.25 contamination floor into NON-adjacent bins, essentially LENGTH-INDEPENDENT (0.240 M16 vs 0.251 M32). This is the diffuse reverb / room+speaker+mic + AAC re-quant tail. It does not improve with longer symbols and is the hard floor that kills 1-bin-spaced K-of-M."
    }
  },
  "_sim": {
    "_about": "Calibrated parameters for the IMPROVED simulator experiments/tape_v2/real_channel_sim.py. These tune the three real-channel terms missing from src/channel.py so the sim reproduces the measured genie BER (M16 ~0.18 RS-uncloseable, M32 RS-closeable). Calibrated against validate_real_sim.py on the master3 H(f).",
    "flutter_residual_frac": 0.15,
    "_flutter_note": "Fraction of the MEASURED flutter that survives the global chirp resample + per-symbol tracker and actually reaches the symbol detector. The frozen channel is driven at flutter_full*this; driving it at the full measured flutter would double-count (sync already removes the bulk) and spuriously punish long symbols.",
    "diffuse_gain": 0.5,
    "_diffuse_note": "Energy gain of the convolutional DIFFUSE tail (length-independent ~25% cross-bin floor: reverb + room/speaker/mic + AAC re-quant).",
    "adj_tail_samples": 20.0,
    "adj_gain": 1.0,
    "_adj_note": "Short reverb tail of FIXED length in SAMPLES -> its corrupting FRACTION shrinks with symbol length, reproducing adjacent-bin leakage 0.112 (M16) -> 0.047 (M32).",
    "eq_clip": 0.05,
    "_eq_clip_note": "Per-tone sounder-EQ lower clip used by the detector. The real m2_modem_survival used 1e-3, but that over-amplifies M32's deep-HF tones (~23x) and spuriously inflates M32 BER in sim; 0.05 reflects a realistic regularized EQ and lets M32's narrower-bin advantage show, matching the real M32-survives finding."
  },
  "sim_gap": {
    "channel_py_models": [
      "band-limit (HF rolloff approx)",
      "wow/flutter time-warp",
      "AWGN",
      "dropouts",
      "speed offset"
    ],
    "channel_py_missing": [
      "acoustic reverb / room impulse response",
      "spectral leakage across adjacent tone bins",
      "speaker+mic coloration beyond simple band-limit",
      "AAC (Voice-Memos) re-quantization artifacts"
    ],
    "consequence": "The omitted terms contaminate adjacent + distant tone bins (~37% off-tone energy on M16). The sim's clean channel made short-symbol M16 look great (more rate); real audio floors a GENIE M16 decoder at bit-BER ~0.17-0.20. Adding the reverb/leakage term below makes the sim punish short symbols the way reality does."
  }
}